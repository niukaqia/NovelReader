贝内特家的五个女儿中，简嫁给了彬格莱先生，伊丽莎白嫁给了达西先生，玛丽嫁给了一位牧师，凯蒂嫁给了一位军官，莉迪亚嫁给了韦翰先生。

贝内特太太非常高兴，她觉得自己的女儿们都找到了幸福。她经常对别人说：“我的女儿们真是太幸运了！”

贝内特先生也很高兴，他觉得自己的女儿们都嫁给了很好的人。他经常对别人说：“我的女儿们真是太聪明了！”

从此，贝内特家过上了幸福快乐的生活。`
  }
];

interface FileParseResult {
  name: string;
  author: string;
}

export class BookScanService {
  private static instance: BookScanService;

  private constructor() {}

  public static getInstance(): BookScanService {
    if (!BookScanService.instance) {
      BookScanService.instance = new BookScanService();
    }
    return BookScanService.instance;
  }

  private generateId(): string {
    return Date.now().toString(36) + Math.random().toString(36).substr(2);
  }

  private parseFileName(fileName: string): FileParseResult {
    let name: string = fileName;
    let author: string = '未知作者';

    const patterns: RegExp[] = [
      /(.+)作者(.+)/,
      /(.+)著(.+)/,
      /(.+)by(.+)/,
      /(.+)-(.*)/,
      /(.+)_([^_]+)/
    ];

    for (let i: number = 0; i < patterns.length; i++) {
      const pattern: RegExp = patterns[i];
      const match: RegExpExecArray | null = pattern.exec(fileName);
      if (match && match.length >= 3) {
        name = match[1].trim();
        author = match[2].trim();
        break;
      }
    }

    return { name, author };
  }

  private extractExtension(filePath: string): string {
    const lastDotIndex: number = filePath.lastIndexOf('.');
    if (lastDotIndex !== -1) {
      return filePath.substring(lastDotIndex).toLowerCase();
    }
    return '';
  }

  private countTxtChapters(content: string): number {
    const chapterPatterns: RegExp[] = [
      /第[一二三四五六七八九十百千万0-9]+[章节回卷]/g,
      /^\s*[第]?\d+[\.、]\s*/gm
    ];

    let count: number = 0;
    for (let i: number = 0; i < chapterPatterns.length; i++) {
      const pattern: RegExp = chapterPatterns[i];
      const matches: RegExpMatchArray | null = content.match(pattern);
      if (matches) {
        count = Math.max(count, matches.length);
      }
    }

    return count > 0 ? count : 1;
  }

  private async scanDirectory(dirPath: string, books: Book[]): Promise<void> {
    try {
      const fileList: string[] = await fileIo.listFile(dirPath);
      const listLen: number = fileList.length;
      for (let i: number = 0; i < listLen; i++) {
        const fileName: string = fileList[i];
        const fullPath: string = dirPath + '/' + fileName;
        const stat = fileIo.statSync(fullPath);

        if (stat.isDirectory()) {
          await this.scanDirectory(fullPath, books);
        } else {
          const ext: string = this.extractExtension(fileName);
          if (SUPPORTED_EXTENSIONS.includes(ext)) {
            let exists: boolean = false;
            const booksLen: number = books.length;
            for (let j: number = 0; j < booksLen; j++) {
              if (books[j].filePath === fullPath) {
                exists = true;
                break;
              }
            }
            if (!exists) {
              const bookName: string = fileName.replace(ext, '');
              const parseResult: FileParseResult = this.parseFileName(bookName);
              const name: string = parseResult.name;
              const author: string = parseResult.author;

              let totalChapters: number = 1;
              let contentAuthor: string = '';
              if (ext === '.txt') {
                try {
                  const file = fileIo.openSync(fullPath, fileIo.OpenMode.READ_ONLY);
                  const content: string = fileIo.readTextSync(fullPath);
                  totalChapters = this.countTxtChapters(content);
                  const authorMatch = content.match(/^作者[：:]\s*(.+)/);
                  if (authorMatch) {
                    contentAuthor = authorMatch[1].trim();
                  }
                  fileIo.closeSync(file);
                } catch (readErr) {
                  console.error(TAG, `Failed to read file ${fullPath}, error: ${(readErr as BusinessError).message}`);
                }
              }

              let category: string = '其他';
              const testBook = TEST_BOOKS.find(b => b.name === (name || bookName));
              if (testBook) {
                category = testBook.category;
              }

              const book: Book = {
                id: this.generateId(),
                name: name || bookName,
                author: contentAuthor || author,
                filePath: fullPath,
                fileType: ext === '.epub' ? 'epub' : 'txt',
                totalChapters: totalChapters,
                lastReadChapter: 0,
                lastReadProgress: 0,
                lastReadTime: 0,
                category: category
              };
              books.push(book);
            }
          }
        }
      }
    } catch (err) {
      console.error(TAG, `Failed to scan directory ${dirPath}, error: ${(err as BusinessError).message}`);
    }
  }

  async scanAllBooks(): Promise<Book[]> {
    const books: Book[] = [];
    const context = getGlobalContext();

    try {
      const filesDir: string = context.filesDir;
      await this.scanDirectory(filesDir, books);
    } catch (err) {
      console.error(TAG, `Failed to access filesDir, error: ${(err as BusinessError).message}`);
    }

    try {
      const cacheDir: string = context.cacheDir;
      await this.scanDirectory(cacheDir, books);
    } catch (err) {
      console.error(TAG, `Failed to access cacheDir, error: ${(err as BusinessError).message}`);
    }

    try {
      const docsDir: string = context.distributedFilesDir;
      await this.scanDirectory(docsDir, books);
    } catch (err) {
      console.error(TAG, `Failed to access docsDir, error: ${(err as BusinessError).message}`);
    }

    const publicPaths: string[] = [
      '/data/storage/el2/base/media/books',
      '/data/storage/el2/base/media/Download',
      '/data/storage/el2/base/media/Documents',
      '/data/storage/el2/base/storage/emulated/0/books',
      '/data/storage/el2/base/storage/emulated/0/Download',
      '/data/storage/el2/base/storage/emulated/0/Documents'
    ];

    for (let i: number = 0; i < publicPaths.length; i++) {
      try {
        await this.scanDirectory(publicPaths[i], books);
      } catch (err) {
        console.error(TAG, `Failed to access ${publicPaths[i]}, error: ${(err as BusinessError).message}`);
      }
    }

    return books;
  }

  scanSingleFile(filePath: string): Book | null {
    try {
      const stat = fileIo.statSync(filePath);
      if (!stat.isFile()) {
        return null;
      }

      const ext: string = this.extractExtension(filePath);
      if (!SUPPORTED_EXTENSIONS.includes(ext)) {
        return null;
      }

      const pathParts: string[] = filePath.split('/');
      const fileName: string = pathParts[pathParts.length - 1] || '';
      const bookName: string = fileName.replace(ext, '');
      const parseResult: FileParseResult = this.parseFileName(bookName);
      const name: string = parseResult.name;
      const author: string = parseResult.author;

      let totalChapters: number = 1;
      if (ext === '.txt') {
        const content: string = fileIo.readTextSync(filePath);
        totalChapters = this.countTxtChapters(content);
      }

      let category: string = '其他';
      const testBook = TEST_BOOKS.find(b => b.name === (name || bookName));
      if (testBook) {
        category = testBook.category;
      }

      const book: Book = {
        id: this.generateId(),
        name: name || bookName,
        author: author,
        filePath: filePath,
        fileType: ext === '.epub' ? 'epub' : 'txt',
        totalChapters: totalChapters,
        lastReadChapter: 0,
        lastReadProgress: 0,
        lastReadTime: 0,
        category: category
      };

      return book;
    } catch (err) {
      console.error(TAG, `Failed to scan file ${filePath}, error: ${(err as BusinessError).message}`);
      return null;
    }
  }

  getSupportedExtensions(): string[] {
    const result: string[] = [];
    const len: number = SUPPORTED_EXTENSIONS.length;
    for (let i: number = 0; i < len; i++) {
      result.push(SUPPORTED_EXTENSIONS[i]);
    }
    return result;
  }

  async createTestBooks(): Promise<void> {
    const context = getGlobalContext();
    const filesDir: string = context.filesDir;

    for (let i: number = 0; i < TEST_BOOKS.length; i++) {
      const book = TEST_BOOKS[i];
      const filePath = `${filesDir}/${book.name}.txt`;

      try {
        const stat = fileIo.statSync(filePath);
        if (stat.isFile()) {
          continue;
        }
      } catch {}

      try {
        const file = fileIo.openSync(filePath, fileIo.OpenMode.READ_WRITE | fileIo.OpenMode.CREATE);
        fileIo.writeSync(file.fd, book.content);
        fileIo.closeSync(file.fd);
        console.info(TAG, `Created test book: ${filePath}`);
      } catch (err) {
        console.error(TAG, `Failed to create test book ${filePath}, error: ${(err as BusinessError).message}`);
      }
    }
  }

  async selectBookFile(): Promise<Book | null> {
    try {
      const documentSelectOptions: picker.DocumentSelectOptions = new picker.DocumentSelectOptions();
      documentSelectOptions.maxSelectNumber = 1;

      const documentViewPicker: picker.DocumentViewPicker = new picker.DocumentViewPicker();
      const selectResult: string[] = await documentViewPicker.select(documentSelectOptions);

      if (selectResult && selectResult.length > 0) {
        const uri: string = selectResult[0];
        const book: Book | null = this.scanSingleFile(uri);
        return book;
      }

      return null;
    } catch (err) {
      console.error(TAG, `Failed to select book file, error: ${(err as BusinessError).message}`);
      return null;
    }
  }

  async selectMultipleBooks(): Promise<Book[]> {
    const books: Book[] = [];
    try {
      const documentSelectOptions: picker.DocumentSelectOptions = new picker.DocumentSelectOptions();
      documentSelectOptions.maxSelectNumber = 10;

      const documentViewPicker: picker.DocumentViewPicker = new picker.DocumentViewPicker();
      const selectResult: string[] = await documentViewPicker.select(documentSelectOptions);

      if (selectResult && selectResult.length > 0) {
        const len: number = selectResult.length;
        for (let i: number = 0; i < len; i++) {
          const uri: string = selectResult[i];
          const book: Book | null = this.scanSingleFile(uri);
          if (book) {
            books.push(book);
          }
        }
      }
    } catch (err) {
      console.error(TAG, `Failed to select multiple books, error: ${(err as BusinessError).message}`);
    }

    return books;
  }
}